.git/
.gitignore
.gitattributes

# 日志
*.log
logs/

# 临时文件
*.tmp
*.bak
*.swp
*~

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# 文档
README.md
docs/
*.md

# 测试
**/src/test/
